{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Zarklab-AI/zark-media",
  "title": "Zark Creative Media",
  "description": "Create and edit creator-ready images and videos with Zark.",
  "version": "1.0.0",
  "websiteUrl": "https://zarklab.ai",
  "repository": {
    "url": "https://github.com/Zarklab-AI/zark-mcp",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.zarklab.ai/v1/mcp",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "Your Zark API key.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "categories": [
        "media-generation",
        "image-generation",
        "video-generation",
        "creator-tools"
      ],
      "homepage": "https://zarklab.ai",
      "documentation": "https://docs.zarklab.ai/agent-integrations/mcp",
      "tagline": "Create and edit creator-ready images and videos from any MCP agent.",
      "tags": [
        "mcp",
        "image-generation",
        "video-generation",
        "creative-tools",
        "media"
      ]
    }
  }
}

